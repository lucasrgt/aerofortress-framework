{
  "stryker-config": {
    "project": "Sample.Api.csproj",
    "mutate": [
      "Modules/**/Features/*.cs",
      "BuildingBlocks/*.cs",
      "!**/*.Tests.cs"
    ],
    "test-case-filter": "Category=Unit",
    "ignore-mutations": ["string"],
    "ignore-methods": ["SaveChangesAsync"],
    "thresholds": { "high": 95, "low": 90, "break": 90 },
    "reporters": ["progress", "cleartext"]
  }
}
