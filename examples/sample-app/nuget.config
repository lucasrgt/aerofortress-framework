<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- The AVP backend adapter (Assay.Net) ships from the avp repo; vendored here so the sample stays
         self-contained and demonstrates the framework -> AVP dependency direction. This is additive: nuget.org
         (from the global config) still resolves xUnit, EF, etc. Master feed: avp/assay.net/local-feed. -->
    <add key="avp-vendor" value="vendor/avp-feed" />
  </packageSources>
</configuration>
