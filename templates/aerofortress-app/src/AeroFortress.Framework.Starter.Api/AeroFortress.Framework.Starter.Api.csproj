<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AeroFortress.Framework.Abstractions" Version="3.0.4" />
    <PackageReference Include="AeroFortress.Framework.AspNetCore" Version="3.0.4" />
    <!-- The doctor rides along as a build analyzer. Remove it and the app still compiles and runs
         (Law 2) — you only lose the enforcement. -->
    <PackageReference Include="AeroFortress.Framework.Doctor" Version="3.0.4" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Tests live co-located with the slice. The app assembly never compiles them (no test deps
         ship); the doctor reads them as AdditionalFiles to require each slice has one. -->
    <Compile Remove="**\*.Tests.cs" />
    <AdditionalFiles Include="**\*.Tests.cs" />
    <!-- The doctor reads the module ctx docs (AF0004/AF0005) as AdditionalFiles. -->
    <AdditionalFiles Include="**\*.ctx.md" />
    <!-- Clockwork manifests bind every slice to its executable AVP proofs (AF0030/AF0031). -->
    <AdditionalFiles Include="**\*.spec.toml" />
  </ItemGroup>

</Project>
