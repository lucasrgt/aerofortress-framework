# AeroFortress's security floor for the built-in .NET analyzers (CA*). Curated, not exhaustive: each rule
# here closes a defect class the doctor's LZ* rules don't cover, at error tier so it gates the build
# the same way they do. Removable like the rest of the harness: set <AeroFortressSecurityAnalysis>false
# </AeroFortressSecurityAnalysis> (or remove the package) and the build still compiles and runs.
is_global = true
global_level = 50

# A dropped ambient CancellationToken makes an endpoint uncancellable — requests pile up past the
# client's disconnect. The token is in scope; forward it.
dotnet_diagnostic.CA2016.severity = error

# SQL built from non-constant strings on the ADO surface (IDbCommand/IDataAdapter). The EF Core
# surface is LZ0024's concern; this covers the layer beneath it.
dotnet_diagnostic.CA2100.severity = warning

# Insecure deserializers — running BinaryFormatter (or friends) on attacker-reachable bytes is
# remote code execution, not a style concern.
dotnet_diagnostic.CA2300.severity = error
dotnet_diagnostic.CA2301.severity = error
dotnet_diagnostic.CA2302.severity = error
dotnet_diagnostic.CA2305.severity = error
dotnet_diagnostic.CA2310.severity = error
dotnet_diagnostic.CA2311.severity = error
dotnet_diagnostic.CA2312.severity = error
dotnet_diagnostic.CA2315.severity = error
# Newtonsoft TypeNameHandling != None — the JSON-shaped variant of the same RCE.
dotnet_diagnostic.CA2326.severity = error
dotnet_diagnostic.CA2327.severity = error

# Broken cryptography (MD5/SHA1, DES/RC2) and weak key derivation.
dotnet_diagnostic.CA5350.severity = error
dotnet_diagnostic.CA5351.severity = error
dotnet_diagnostic.CA5379.severity = error
dotnet_diagnostic.CA5387.severity = error

# Certificate validation disabled (the "works in staging" backdoor that ships).
dotnet_diagnostic.CA5359.severity = error

# Hardcoded or deprecated TLS protocol versions — let the OS negotiate.
dotnet_diagnostic.CA5364.severity = error
dotnet_diagnostic.CA5386.severity = error
dotnet_diagnostic.CA5397.severity = error

# Zip-slip: an archive entry path used in file IO without containment.
dotnet_diagnostic.CA5389.severity = error
