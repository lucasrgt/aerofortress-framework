{
  "name": "@aerofortress/frontend-sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Canonical AeroFortress frontend doctor and scaffolding tools.",
  "license": "MIT",
  "author": "Lucas Tinoco",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasrgt/aerofortress-framework.git",
    "directory": "frontend-sdk"
  },
  "homepage": "https://github.com/lucasrgt/aerofortress-framework#readme",
  "bugs": "https://github.com/lucasrgt/aerofortress-framework/issues",
  "keywords": ["aerofortress", "frontend", "doctor", "eslint", "scaffolding"],
  "files": ["tools/*.mjs", "tools/README.md"],
  "exports": {
    "./doctor": "./tools/doctor.mjs",
    "./e2e-doctor": "./tools/e2e-doctor.mjs",
    "./endpoint-coverage": "./tools/endpoint-coverage.mjs",
    "./error-code-coverage": "./tools/error-code-coverage.mjs",
    "./framework-sync": "./tools/framework-sync.mjs",
    "./i18n-parity": "./tools/i18n-parity.mjs",
    "./journey-parity": "./tools/journey-parity.mjs",
    "./package-versions": "./tools/package-versions.mjs"
  },
  "bin": {
    "affe-contract-freshness": "./tools/contract-freshness.mjs",
    "affe-e2e-doctor": "./tools/e2e-doctor.mjs",
    "affe-endpoint-coverage": "./tools/endpoint-coverage.mjs",
    "affe-error-code-coverage": "./tools/error-code-coverage.mjs",
    "affe-framework-sync": "./tools/framework-sync.mjs",
    "affe-i18n-parity": "./tools/i18n-parity.mjs",
    "affe-journey-parity": "./tools/journey-parity.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p packages/aerofortress-react/tsconfig.json",
    "lint": "node packages/eslint-plugin/index.test.cjs",
    "scaffold": "node tools/scaffold-feature.mjs",
    "scaffold:design": "node tools/design-scaffold.mjs",
    "assemble-i18n": "node tools/assemble-i18n.mjs",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/eslint-plugin-query": "^5.62.16",
    "@tanstack/react-query": "^5.62.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/eslint-plugin": "^1.1.43",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-sonarjs": "^3.0.2",
    "i18next": "^24.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^15.4.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  }
}
