{
  "name": "@lazuli/frontend-sdk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "The frontend side of lazuli-net — the spine (@lazuli/react), the eslint-plugin (LZFE rules), and the tools. The canonical sample now lives at examples/sample-app (run via the repo-root vitest below).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p packages/lazuli-react/tsconfig.json",
    "lint": "node packages/eslint-plugin/index.test.cjs",
    "scaffold": "node tools/scaffold-feature.mjs",
    "scaffold:design": "node tools/design-scaffold.mjs",
    "assemble-i18n": "node tools/assemble-i18n.mjs",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/eslint-plugin-query": "^5.62.16",
    "@tanstack/react-query": "^5.62.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/eslint-plugin": "^1.1.43",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "i18next": "^24.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^15.4.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  }
}
