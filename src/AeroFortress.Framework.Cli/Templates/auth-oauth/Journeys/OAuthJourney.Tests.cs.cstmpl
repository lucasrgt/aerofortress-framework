using System.Net;
using System.Net.Http.Json;
using MyApp.Api.Modules.Account;

namespace MyApp.Tests.Journeys;

// Journeys for the OAuth writes. The dev IExternalIdentity (FakeExternalIdentity) treats the
// token as the email and rejects an empty one — so a non-empty token is a "verified" identity and an empty
// token is a forged/unverifiable one. That is the seam: no real provider, but the bypass guard (reject what
// doesn't verify) is the same code path a real verifier would gate. AF0008 requires a happy and a sad each.
public class OAuthJourney
{
    private const string Identity = "g-user@example.com";

    private sealed record Tokens(string AccessToken, string RefreshToken);

    [E2E]
    [Journey(typeof(RegisterWithGoogle), JourneyPath.Happy)]
    [Fact]
    public async Task A_verified_identity_creates_an_account()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();

        var response = await client.PostAsJsonAsync("/account/register/google", new { idToken = Identity });

        response.EnsureSuccessStatusCode();
        var tokens = await response.Content.ReadFromJsonAsync<Tokens>();
        Assert.False(string.IsNullOrWhiteSpace(tokens!.AccessToken));
    }

    // The bypass guard: an unverifiable (empty) token is denied and mints no account/session.
    [E2E]
    [Journey(typeof(RegisterWithGoogle), JourneyPath.Sad)]
    [Fact]
    public async Task An_unverifiable_token_creates_no_account()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();

        var response = await client.PostAsJsonAsync("/account/register/google", new { idToken = "" });

        Assert.Equal(HttpStatusCode.Unauthorized, response.StatusCode);
        var body = await response.Content.ReadAsStringAsync();
        Assert.DoesNotContain("accessToken", body, StringComparison.OrdinalIgnoreCase);
    }

    [E2E]
    [Journey(typeof(LoginWithGoogle), JourneyPath.Happy)]
    [Fact]
    public async Task A_known_identity_signs_in()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        await client.PostAsJsonAsync("/account/register/google", new { idToken = Identity });

        var response = await client.PostAsJsonAsync("/account/login/google", new { idToken = Identity });

        response.EnsureSuccessStatusCode();
        var tokens = await response.Content.ReadFromJsonAsync<Tokens>();
        Assert.False(string.IsNullOrWhiteSpace(tokens!.AccessToken));
    }

    // The takeover guard: an unverifiable token is denied — it never yields a session for any user.
    [E2E]
    [Journey(typeof(LoginWithGoogle), JourneyPath.Sad)]
    [Fact]
    public async Task An_unverifiable_token_is_denied()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        await client.PostAsJsonAsync("/account/register/google", new { idToken = Identity });

        var response = await client.PostAsJsonAsync("/account/login/google", new { idToken = "" });

        Assert.Equal(HttpStatusCode.Unauthorized, response.StatusCode);
    }
}
