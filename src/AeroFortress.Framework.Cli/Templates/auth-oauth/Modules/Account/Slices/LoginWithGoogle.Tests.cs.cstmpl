using MyApp.Api;
using AeroFortress.Framework.Auth;
using MyApp.Api.Modules.Account;
using MyApp.Api.Tenancy;
using AeroFortress.Framework.Identity;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class LoginWithGoogleTests
{
    [Unit]
    [Fact]
    public async Task Signs_in_an_existing_user()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        await SeedUser(org, store, "g@x.com");

        await using var db = NewDb(org, store);
        var result = await LoginWithGoogle.Handle(new LoginWithGoogle.Input("g@x.com"), db, new FakeExternalIdentity(), Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_identity()
    {
        await using var db = NewDb(Guid.NewGuid());
        var result = await LoginWithGoogle.Handle(new LoginWithGoogle.Input("nobody@x.com"), db, new FakeExternalIdentity(), Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    private static async Task SeedUser(Guid org, string store, string email)
    {
        await using var db = NewDb(org, store);
        await Register.Handle(new Register.Input(email, "password1"), db, TimeProvider.System, default);
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    private static AppDb NewDb(Guid org, string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options, new Tenant { OrgId = org });
}
