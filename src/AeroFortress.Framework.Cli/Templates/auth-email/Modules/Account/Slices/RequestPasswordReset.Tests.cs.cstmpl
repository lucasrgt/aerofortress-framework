using MyApp.Api;
using MyApp.Api.Modules.Account;
using MyApp.Api.Tenancy;
using AeroFortress.Framework.Mail;
using Microsoft.EntityFrameworkCore;
using Assay.Net;

namespace MyApp.Tests.Modules.Account;

public class RequestPasswordResetTests
{
    [AVP(typeof(RequestPasswordReset), "does-not-reveal-account-existence")]
    [Unit]
    [Fact]
    public async Task Creates_a_reset_token_for_a_known_email()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store, "a@x.com");

        await using var db = NewDb(org, store);
        var result = await RequestPasswordReset.Handle(new RequestPasswordReset.Input("a@x.com"), db, new ConsoleEmailSender(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.True(await db.PasswordResetTokens.AnyAsync(t => t.UserId == userId && t.UsedAt == null));
    }

    [Unit]
    [Fact]
    public async Task Returns_success_for_an_unknown_email_without_creating_a_token()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();

        await using var db = NewDb(org, store);
        var result = await RequestPasswordReset.Handle(new RequestPasswordReset.Input("nobody@x.com"), db, new ConsoleEmailSender(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.False(await db.PasswordResetTokens.AnyAsync());
    }

    private static async Task<Guid> SeedUser(Guid org, string store, string email)
    {
        await using var db = NewDb(org, store);
        var r = await Register.Handle(new Register.Input(email, "password1"), db, TimeProvider.System, default);
        return r.Value.UserId;
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
