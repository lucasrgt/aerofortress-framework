using System.Net;
using System.Net.Http.Headers;
using System.Net.Http.Json;
using MyApp.Api.Modules.Account;
using AeroFortress.Framework.Sms;
using Microsoft.AspNetCore.Hosting;
using Microsoft.Extensions.DependencyInjection;

namespace MyApp.Tests.Journeys;

// Journey for the [Critical] VerifyPhone slice. Phone verification can't be driven purely over HTTP — the
// OTP is hashed in storage and only leaves the system as an SMS — so the test layers a capturing ISmsSender
// over the booted app (the last registration wins) to read the code the real ResendPhoneCode slice sent.
// That layering is exactly what the framework's host hook is for; the rest of the stack is the real one.
public class PhoneVerificationJourney
{
    private const string Email = "phone@example.com";
    private const string Password = "password1";
    private const string Phone = "+5511999999999";

    private sealed record Tokens(string AccessToken, string RefreshToken);

    // Reads the code out of the SMS body the slice sends ("Your MyApp code is 123456" → "123456").
    private sealed class CapturingSmsSender : ISmsSender
    {
        public string? LastCode { get; private set; }

        public Task SendAsync(string toPhone, string message, CancellationToken ct = default)
        {
            LastCode = new string(message.Where(char.IsDigit).ToArray());
            return Task.CompletedTask;
        }
    }

    [E2E]
    [Journey(typeof(VerifyPhone), JourneyPath.Happy)]
    [Fact]
    public async Task The_code_from_the_sms_verifies_the_phone()
    {
        var sms = new CapturingSmsSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<ISmsSender>(sms)));
        var client = factory.CreateClient();
        await Authenticate(client);

        await client.PostAsJsonAsync("/account/phone-code", new { phone = Phone });
        var verify = await client.PostAsJsonAsync("/account/verify-phone", new { code = sms.LastCode });

        verify.EnsureSuccessStatusCode();
    }

    // The bypass guard: a wrong code is rejected, and it neither falsely verifies nor burns the OTP — the
    // real code still verifies right after. A silent pass here would mark a phone verified without the code.
    [E2E]
    [Journey(typeof(VerifyPhone), JourneyPath.Sad)]
    [Fact]
    public async Task A_wrong_code_is_rejected_and_the_real_code_still_verifies()
    {
        var sms = new CapturingSmsSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<ISmsSender>(sms)));
        var client = factory.CreateClient();
        await Authenticate(client);
        await client.PostAsJsonAsync("/account/phone-code", new { phone = Phone });

        var wrong = sms.LastCode == "000000" ? "000001" : "000000";
        var rejected = await client.PostAsJsonAsync("/account/verify-phone", new { code = wrong });
        Assert.Equal(HttpStatusCode.Unauthorized, rejected.StatusCode);

        // No false verification, no consumed OTP: the genuine code still works.
        var verify = await client.PostAsJsonAsync("/account/verify-phone", new { code = sms.LastCode });
        verify.EnsureSuccessStatusCode();
    }

    private static async Task Authenticate(HttpClient client)
    {
        await client.PostAsJsonAsync("/account/register", new { email = Email, password = Password });
        var login = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        login.EnsureSuccessStatusCode();
        var tokens = await login.Content.ReadFromJsonAsync<Tokens>();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", tokens!.AccessToken);
    }
}
