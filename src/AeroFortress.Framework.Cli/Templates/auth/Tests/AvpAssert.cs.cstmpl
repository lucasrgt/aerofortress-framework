using Assay.Net;

namespace MyApp.Tests;

/// <summary>Asserts that every named AVP criterion was scored and passed, preserving the verifier's reason in
/// the test failure so a broken invariant is diagnosable rather than reduced to a bare boolean.</summary>
internal static class AvpAssert
{
    public static void Passes(Verdict verdict, params string[] criterionIds)
    {
        foreach (var id in criterionIds)
        {
            var result = verdict.Results.FirstOrDefault(candidate => candidate.CriterionId == id);
            Assert.True(result is not null, $"the verdict for '{verdict.Subject}' scored no criterion '{id}'.");
            Assert.True(result!.Status == VerdictStatus.Pass, $"[{id}] {result.Status}: {result.Reason}");
        }
    }
}
