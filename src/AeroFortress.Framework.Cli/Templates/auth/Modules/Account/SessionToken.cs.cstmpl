using System.Buffers.Text;
using System.Security.Cryptography;
using System.Text;

namespace MyApp.Api.Modules.Account;

/// <summary>
/// Issues and hashes session tokens. A token is high-entropy random, so it is stored as a plain
/// SHA-256 hash — deterministic, so a presented token is hashed and looked up directly. This is the
/// opposite of <see cref="PasswordHash"/>: passwords are low-entropy and need a slow salted hash
/// (argon2); a random token does not, and a slow per-salt hash could not be looked up at all.
/// </summary>
public static class SessionToken
{
    /// <summary>How long a refresh token (and so a login) stays valid. One source for the DB row's
    /// expiry and the web cookie's Max-Age, so they can never drift apart.</summary>
    public static readonly TimeSpan Lifetime = TimeSpan.FromDays(14);

    /// <summary>The absolute ceiling on a session's age, measured from the family's first token. A family
    /// may rotate (slide) freely within this window, but once its lineage is older than this it is retired
    /// on the next refresh — forcing a fresh login. Caps how long a silently-rotating session can live no
    /// matter how often it refreshes.</summary>
    public static readonly TimeSpan FamilyMaxAge = TimeSpan.FromDays(90);

    /// <summary>The grace window after a token is rotated within which presenting it again is treated as a
    /// <em>benign</em> concurrent refresh — two tabs sharing one httpOnly cookie, or a double-bootstrap — not
    /// theft. Within the window the reuse gets a transient "retry" (the client re-reads the rotated cookie);
    /// only a reuse <em>after</em> it burns the family. Short, because a real leaked token is replayed long
    /// after the legit client has rotated, while a cross-tab race fires near-simultaneously.</summary>
    public static readonly TimeSpan RefreshReuseGrace = TimeSpan.FromSeconds(10);

    /// <summary>Mint a fresh token: the raw value (returned to the client once) and its stored hash.
    /// Base64Url, so the token is safe to carry in a cookie or URL without escaping (no <c>+ / =</c>).</summary>
    public static (string Raw, string Hash) Issue()
    {
        var raw = Base64Url.EncodeToString(RandomNumberGenerator.GetBytes(32));
        return (raw, Hash(raw));
    }

    /// <summary>The lookup hash of a presented token.</summary>
    public static string Hash(string raw) =>
        Convert.ToHexString(SHA256.HashData(Encoding.UTF8.GetBytes(raw)));
}
