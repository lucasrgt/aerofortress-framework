using MyApp.Api;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class RegisterTests
{
    [Unit]
    [Fact]
    public async Task Creates_a_user_with_a_normalized_email_and_verifiable_hash()
    {
        await using var db = NewDb();

        var result = await Register.Handle(new Register.Input("Alice@Example.com ", "s3cret-pw"), db, TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        var user = await db.Users.FindAsync(result.Value.UserId);
        Assert.Equal("alice@example.com", user!.Email.Value);
        Assert.True(user.PasswordHash.Verify("s3cret-pw"));
        Assert.False(user.PasswordHash.Verify("wrong-pw"));
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_duplicate_email()
    {
        var store = Guid.NewGuid().ToString();
        await using (var first = NewDb(store))
            await Register.Handle(new Register.Input("a@x.com", "password1"), first, TimeProvider.System, default);

        await using var second = NewDb(store);
        var result = await Register.Handle(new Register.Input("a@x.com", "password1"), second, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Conflict, result.Error.Kind);
    }

    //<lz:tenancy>
    [Unit]
    [Fact]
    public async Task The_same_email_is_rejected_even_in_a_different_org()
    {
        // Global identity: email is one-human-one-account, so a taken email is taken everywhere — the
        // uniqueness check crosses the tenant filter.
        var store = Guid.NewGuid().ToString();
        await using (var orgA = NewDb(store, Guid.NewGuid()))
            await Register.Handle(new Register.Input("a@x.com", "password1"), orgA, TimeProvider.System, default);

        await using var orgB = NewDb(store, Guid.NewGuid());
        var result = await Register.Handle(new Register.Input("a@x.com", "password1"), orgB, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Conflict, result.Error.Kind);
    }
    //</lz:tenancy>

    [Unit]
    [Fact]
    public async Task Rejects_an_invalid_email()
    {
        await using var db = NewDb();

        var result = await Register.Handle(new Register.Input("not-an-email", "password1"), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Validation, result.Error.Kind);
    }

    //<lz:tenancy>
    private static AppDb NewDb(string? store = null, Guid? org = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options,
            new Tenant { OrgId = org ?? Guid.NewGuid() });
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options);
    //</lz:!tenancy>
}
