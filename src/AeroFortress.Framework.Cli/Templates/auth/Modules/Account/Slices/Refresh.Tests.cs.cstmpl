using MyApp.Api;
using AeroFortress.Framework.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class RefreshTests
{
    [Unit]
    [Fact]
    public async Task Rotates_and_returns_a_fresh_pair()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);

        await using var db = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
        Assert.NotEqual(refresh, result.Value.RefreshToken);
    }

    [Unit]
    [Fact]
    public async Task The_rotated_token_cannot_mint_a_new_pair()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);
        await using (var db = NewDb(store))
            await Refresh.Handle(new Refresh.Input(refresh), db, Tokens(), TimeProvider.System, default);

        await using var reuse = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), reuse, Tokens(), TimeProvider.System, default);

        // Immediately after rotation the reuse is a benign retry (inside the grace window), not theft — but it
        // still mints no new pair: a spent token can never be exchanged again.
        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Reuse_within_the_grace_window_is_a_benign_retry()
    {
        var store = Guid.NewGuid().ToString();
        var clock = new MutableClock(DateTimeOffset.UtcNow);
        var first = await SeedAndLogin(store, clock);

        // Rotate first → second at T.
        string second;
        await using (var db = NewDb(store))
            second = (await Refresh.Handle(new Refresh.Input(first), db, Tokens(), clock, default)).Value.RefreshToken;

        // Replay the spent first 5s later — inside the 10s grace window: a benign concurrent refresh (a shared
        // cookie across tabs), not theft. It is rejected with a transient retry and the family is NOT burned.
        clock.Advance(TimeSpan.FromSeconds(5));
        await using (var db = NewDb(store))
        {
            var replay = await Refresh.Handle(new Refresh.Input(first), db, Tokens(), clock, default);
            Assert.True(replay.IsFailure);
            Assert.Equal(ErrorKind.Unauthorized, replay.Error.Kind);
            Assert.Equal(AccountErrorCodes.SessionRetry, replay.Error.Code);
        }

        // The live rotated token still works — the concurrent replay did not kill the family.
        await using (var db = NewDb(store))
        {
            var rotated = await Refresh.Handle(new Refresh.Input(second), db, Tokens(), clock, default);
            Assert.True(rotated.IsSuccess);
        }
    }

    [Unit]
    [Fact]
    public async Task Reuse_after_the_grace_window_burns_the_whole_family()
    {
        var store = Guid.NewGuid().ToString();
        var clock = new MutableClock(DateTimeOffset.UtcNow);
        var original = await SeedAndLogin(store, clock);

        string fresh;
        await using (var db = NewDb(store))
            fresh = (await Refresh.Handle(new Refresh.Input(original), db, Tokens(), clock, default)).Value.RefreshToken;

        // Replay the spent original well after the grace window — a genuine leaked-token replay: theft → the
        // whole family is burned.
        clock.Advance(SessionToken.RefreshReuseGrace + TimeSpan.FromSeconds(1));
        await using (var db = NewDb(store))
        {
            var reuse = await Refresh.Handle(new Refresh.Input(original), db, Tokens(), clock, default);
            Assert.True(reuse.IsFailure);
            Assert.Equal(ErrorKind.Unauthorized, reuse.Error.Kind);
            Assert.Equal(AccountErrorCodes.SessionRevoked, reuse.Error.Code);
        }

        // The fresh token issued before the theft is dead too — the whole family went down.
        await using (var after = NewDb(store))
        {
            var result = await Refresh.Handle(new Refresh.Input(fresh), after, Tokens(), clock, default);
            Assert.True(result.IsFailure);
        }
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_family_past_the_absolute_max_age()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);

        // Age the family past the ceiling without expiring the token itself: backdate its only slot's
        // first-seen time beyond FamilyMaxAge (through EF metadata, since CreatedAt is encapsulated), leaving
        // ExpiresAt in the future — so it is the absolute-age ceiling that retires it, not ordinary expiry.
        await using (var db = NewDb(store))
        {
            var slot = await db.UserSessions.FirstAsync();
            db.Entry(slot).Property(s => s.CreatedAt).CurrentValue =
                DateTime.UtcNow - SessionToken.FamilyMaxAge - TimeSpan.FromDays(1);
            await db.SaveChangesAsync();
        }

        await using var aged = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), aged, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_token()
    {
        await using var db = NewDb();

        var result = await Refresh.Handle(new Refresh.Input("not-a-real-token"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    private static async Task<string> SeedAndLogin(string store, TimeProvider clock)
    {
        await using var db = NewDb(store);
        await Register.Handle(new Register.Input("a@x.com", "password1"), db, clock, default);
        var login = await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), clock, default);
        return login.Value.RefreshToken;
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    // A controllable clock so the grace-window and absolute-age behaviours are deterministic — no real waiting.
    private sealed class MutableClock(DateTimeOffset start) : TimeProvider
    {
        private DateTimeOffset _now = start;
        public override DateTimeOffset GetUtcNow() => _now;
        public void Advance(TimeSpan by) => _now = _now.Add(by);
    }

    //<lz:tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options,
            new Tenant { OrgId = Guid.NewGuid() });
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options);
    //</lz:!tenancy>
}
