using MyApp.Api;
using AeroFortress.Framework.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class RefreshTests
{
    [Unit]
    [Fact]
    public async Task Rotates_and_returns_a_fresh_pair()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);

        await using var db = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
        Assert.NotEqual(refresh, result.Value.RefreshToken);
    }

    [Unit]
    [Fact]
    public async Task Replaying_the_rotated_token_burns_the_whole_family_immediately()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);
        string live;
        await using (var db = NewDb(store))
            live = (await Refresh.Handle(new Refresh.Input(refresh), db, Tokens(), TimeProvider.System, default)).Value.RefreshToken;

        await using var reuse = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), reuse, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
        Assert.Equal(AccountErrorCodes.SessionRevoked, result.Error.Code);

        // The live token issued before the replay is dead too — theft burns the whole lineage.
        await using (var after = NewDb(store))
        {
            var family = await Refresh.Handle(new Refresh.Input(live), after, Tokens(), TimeProvider.System, default);
            Assert.True(family.IsFailure);
        }
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_family_past_the_absolute_max_age()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store, TimeProvider.System);

        // Age the family past the ceiling without expiring the token itself: backdate its only slot's
        // first-seen time beyond FamilyMaxAge (through EF metadata, since CreatedAt is encapsulated), leaving
        // ExpiresAt in the future — so it is the absolute-age ceiling that retires it, not ordinary expiry.
        await using (var db = NewDb(store))
        {
            var slot = await db.UserSessions.FirstAsync();
            db.Entry(slot).Property(s => s.CreatedAt).CurrentValue =
                DateTime.UtcNow - SessionToken.FamilyMaxAge - TimeSpan.FromDays(1);
            await db.SaveChangesAsync();
        }

        await using var aged = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), aged, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_token()
    {
        await using var db = NewDb();

        var result = await Refresh.Handle(new Refresh.Input("not-a-real-token"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    private static async Task<string> SeedAndLogin(string store, TimeProvider clock)
    {
        await using var db = NewDb(store);
        await Register.Handle(new Register.Input("a@x.com", "password1"), db, clock, default);
        var login = await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), clock, default);
        return login.Value.RefreshToken;
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    //<lz:tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options,
            new Tenant { OrgId = Guid.NewGuid() });
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options);
    //</lz:!tenancy>
}
