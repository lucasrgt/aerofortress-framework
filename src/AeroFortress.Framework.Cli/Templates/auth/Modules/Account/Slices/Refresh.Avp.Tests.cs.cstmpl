using System.Net.Http.Json;
using Assay.Net;
using Assay.Net.Archetypes;
using MyApp.Api.Modules.Account;

namespace MyApp.Tests.Modules.Account;

/// <summary>Proves the real Refresh endpoint rotates live tokens and burns the complete family when a spent
/// token is replayed. The obligations are declared in Account.spec.toml.</summary>
public class RefreshAvpProof
{
    private static readonly ProtocolCatalog Avp = Catalog.LoadDefault();

    [AVP(typeof(Refresh), "rotates-on-refresh")]
    [AVP(typeof(Refresh), "replay-burns-family")]
    [Integration]
    [Fact]
    public async Task Refresh_rotates_and_a_replay_burns_the_family()
    {
        await using var app = new TestApp();
        (await app.CreateClient().PostAsJsonAsync(
                "/account/register", new { email = "avp-refresh@x.com", password = "password1" }))
            .EnsureSuccessStatusCode();

        var subject = new TokenRotationSubject(
            BaseUrl: "http://in-memory",
            LoginPath: "/account/login",
            Credentials: new { email = "avp-refresh@x.com", password = "password1" },
            RefreshPath: "/account/refresh");

        var verdict = await Runner.Run(Avp, new TokenRotation(), nameof(Refresh), subject,
            transport: () => app.CreateClient());

        AvpAssert.Passes(verdict, "rotates-on-refresh", "replay-burns-family");
    }
}
