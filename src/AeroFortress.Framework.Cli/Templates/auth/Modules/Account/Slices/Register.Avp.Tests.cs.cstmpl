using Assay.Net;
using Assay.Net.Archetypes;
using MyApp.Api.Modules.Account;

namespace MyApp.Tests.Modules.Account;

/// <summary>Proves the real Register endpoint rejects a second account with the same email, preserving the
/// one-email-one-account invariant declared in Account.spec.toml.</summary>
public class RegisterAvpProof
{
    private static readonly ProtocolCatalog Avp = Catalog.LoadDefault();

    [AVP(typeof(Register), "rejects-duplicate")]
    [Integration]
    [Fact]
    public async Task Register_rejects_a_duplicate_email()
    {
        await using var app = new TestApp();
        var subject = new ResourceUniquenessSubject(
            BaseUrl: "http://in-memory",
            CreatePath: "/account/register",
            Body: new { email = "avp-duplicate@x.com", password = "password1" });

        var verdict = await Runner.Run(Avp, new ResourceUniqueness(), nameof(Register), subject,
            transport: () => app.CreateClient());

        AvpAssert.Passes(verdict, "rejects-duplicate");
    }
}
