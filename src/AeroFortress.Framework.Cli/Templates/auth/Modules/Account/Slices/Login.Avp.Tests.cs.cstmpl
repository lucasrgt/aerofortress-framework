using System.Net.Http.Json;
using Assay.Net;
using Assay.Net.Archetypes;
using MyApp.Api.Modules.Account;

namespace MyApp.Tests.Modules.Account;

/// <summary>Proves the real Login endpoint is the authority on credentials: invalid credentials issue no
/// token, while valid credentials do. The obligations are declared in Account.spec.toml.</summary>
public class LoginAvpProof
{
    private static readonly ProtocolCatalog Avp = Catalog.LoadDefault();

    [AVP(typeof(Login), "rejects-invalid-credentials")]
    [AVP(typeof(Login), "issues-token-on-valid")]
    [Integration]
    [Fact]
    public async Task Login_is_the_authority_on_credentials()
    {
        await using var app = new TestApp();
        (await app.CreateClient().PostAsJsonAsync(
                "/account/register", new { email = "avp-login@x.com", password = "password1" }))
            .EnsureSuccessStatusCode();

        var subject = new CredentialAuthoritySubject(
            BaseUrl: "http://in-memory",
            LoginPath: "/account/login",
            ValidCredentials: new { email = "avp-login@x.com", password = "password1" },
            InvalidCredentials: new { email = "avp-login@x.com", password = "wrong-password" });

        var verdict = await Runner.Run(Avp, new CredentialAuthority(), nameof(Login), subject,
            transport: () => app.CreateClient());

        AvpAssert.Passes(verdict, "rejects-invalid-credentials", "issues-token-on-valid");
    }
}
