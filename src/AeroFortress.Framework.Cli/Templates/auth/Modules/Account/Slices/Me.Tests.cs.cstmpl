using MyApp.Api;
using AeroFortress.Framework.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class MeTests
{
    [Unit]
    [Fact]
    public async Task Returns_the_signed_in_user()
    {
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(store, "a@x.com", "password1");

        await using var db = NewDb(store);
        var result = await Me.Handle(new Me.Input(), db, new FakeUser(userId), default);

        Assert.True(result.IsSuccess);
        Assert.Equal(userId, result.Value.UserId);
        Assert.Equal("a@x.com", result.Value.Email);
    }

    private static async Task<Guid> SeedUser(string store, string email, string password)
    {
        await using var db = NewDb(store);
        var result = await Register.Handle(new Register.Input(email, password), db, TimeProvider.System, default);
        return result.Value.UserId;
    }

    //<lz:tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = Guid.Empty });

    private sealed class FakeUser(Guid userId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public Guid OrgId => Guid.Empty;
        public string? Role => null;
        public Guid SessionId => Guid.Empty;
    }
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options);

    private sealed class FakeUser(Guid userId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public string? Role => null;
        public Guid SessionId => Guid.Empty;
    }
    //</lz:!tenancy>
}
