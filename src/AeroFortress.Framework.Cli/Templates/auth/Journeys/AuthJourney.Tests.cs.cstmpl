using System.Net;
using System.Net.Http.Json;
using MyApp.Api.Modules.Account;

namespace MyApp.Tests.Journeys;

// Journeys for the [Critical] auth slices. They prove, end-to-end, the failures that a unit test on
// Handle cannot: that a bad credential is denied (no token leaks) and that a replayed refresh token
// burns the whole family (theft detection). Both are security properties of the wired stack — the
// middleware, the token, the rotation — not just of Handle. AF0008 requires a happy and a sad per slice.
//
// No X-Client header → mobile delivery, so the refresh token rides in the body where these tests read it.
public class AuthJourney
{
    private const string Email = "user@example.com";
    private const string Password = "password1";

    // Only the tokens matter here; the enum fields (Step, Role) are ignored on deserialization.
    private sealed record Tokens(string AccessToken, string RefreshToken);

    [E2E]
    [Journey(typeof(Login), JourneyPath.Happy)]
    [Fact]
    public async Task Valid_credentials_yield_a_usable_access_token()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        await Register(client);

        var response = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });

        response.EnsureSuccessStatusCode();
        var tokens = await response.Content.ReadFromJsonAsync<Tokens>();
        Assert.False(string.IsNullOrWhiteSpace(tokens!.AccessToken));
        Assert.False(string.IsNullOrWhiteSpace(tokens.RefreshToken));
    }

    // The bypass guard: a wrong password is denied with 401 and mints no token. A silent inversion of
    // this check is the whole reason Login is [Critical].
    [E2E]
    [Journey(typeof(Login), JourneyPath.Sad)]
    [Fact]
    public async Task Wrong_password_is_denied_and_issues_no_token()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        await Register(client);

        var response = await client.PostAsJsonAsync("/account/login", new { email = Email, password = "wrong-password" });

        Assert.Equal(HttpStatusCode.Unauthorized, response.StatusCode);
        var body = await response.Content.ReadAsStringAsync();
        Assert.DoesNotContain("accessToken", body, StringComparison.OrdinalIgnoreCase);
    }

    [E2E]
    [Journey(typeof(Refresh), JourneyPath.Happy)]
    [Fact]
    public async Task Refresh_rotates_to_a_new_token_pair()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        var first = await Login(client);

        var response = await client.PostAsJsonAsync("/account/refresh", new { refreshToken = first.RefreshToken });

        response.EnsureSuccessStatusCode();
        var rotated = await response.Content.ReadFromJsonAsync<Tokens>();
        Assert.False(string.IsNullOrWhiteSpace(rotated!.AccessToken));
        Assert.NotEqual(first.RefreshToken, rotated.RefreshToken);   // the family rotated
    }

    // The replay path — the highest-stakes sad: a token already rotated is presented again. Within the grace
    // window that is a benign concurrent refresh (two tabs sharing one cookie), so it is rejected as a
    // transient retry but does NOT kill the family — the legitimately-rotated token keeps working. (Theft
    // proper — a replay long after rotation — burns the whole family; that, and the grace boundary, are proven
    // deterministically in RefreshTests with a controllable clock, which an E2E journey cannot advance.)
    [E2E]
    [Journey(typeof(Refresh), JourneyPath.Sad)]
    [Fact]
    public async Task A_replayed_refresh_token_is_rejected_without_killing_the_live_one()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        var first = await Login(client);

        // Legit rotation: first → second.
        var rotated = await (await client.PostAsJsonAsync("/account/refresh", new { refreshToken = first.RefreshToken }))
            .Content.ReadFromJsonAsync<Tokens>();

        // Replay the spent token: rejected — a spent token can never mint a new pair.
        var replay = await client.PostAsJsonAsync("/account/refresh", new { refreshToken = first.RefreshToken });
        Assert.Equal(HttpStatusCode.Unauthorized, replay.StatusCode);

        // The family survives the benign concurrent replay: the legitimately-rotated token still refreshes.
        var live = await client.PostAsJsonAsync("/account/refresh", new { refreshToken = rotated!.RefreshToken });
        live.EnsureSuccessStatusCode();
    }

    [E2E]
    [Journey(typeof(Register), JourneyPath.Happy)]
    [Fact]
    public async Task Registering_a_new_email_creates_a_usable_account()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();

        var response = await client.PostAsJsonAsync("/account/register", new { email = Email, password = Password });

        response.EnsureSuccessStatusCode();
        // The account is real: it can immediately log in.
        var login = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        login.EnsureSuccessStatusCode();
    }

    // The identity guard: a second registration with the same email is rejected, and the first account
    // stays intact and usable — no duplicate, no corruption of the one-human-one-account invariant.
    [E2E]
    [Journey(typeof(Register), JourneyPath.Sad)]
    [Fact]
    public async Task Duplicate_email_is_rejected_and_the_first_account_survives()
    {
        await using var app = new TestApp();
        var client = app.CreateClient();
        await Register(client);

        var duplicate = await client.PostAsJsonAsync("/account/register", new { email = Email, password = "another1" });

        Assert.Equal(HttpStatusCode.Conflict, duplicate.StatusCode);
        // The one real account still works with its original password.
        var login = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        login.EnsureSuccessStatusCode();
    }

    private static async Task Register(HttpClient client) =>
        (await client.PostAsJsonAsync("/account/register", new { email = Email, password = Password }))
            .EnsureSuccessStatusCode();

    private static async Task<Tokens> Login(HttpClient client)
    {
        await Register(client);
        var response = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        response.EnsureSuccessStatusCode();
        return (await response.Content.ReadFromJsonAsync<Tokens>())!;
    }
}
