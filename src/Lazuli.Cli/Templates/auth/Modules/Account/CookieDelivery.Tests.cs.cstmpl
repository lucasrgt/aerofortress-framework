using System.Net.Http.Json;
using Microsoft.AspNetCore.Mvc.Testing;

namespace Hostpoint.Tests.Modules.Account;

// Web delivery: the refresh token rides in an httpOnly cookie and never the JSON body; mobile (no
// header) still gets it in the body. Same endpoints, one X-Client signal. The client here does NOT
// auto-handle cookies, so the raw Set-Cookie is visible and the cookie is replayed by hand.
public class CookieDeliveryTests
{
    // The name AccountSetup configures via AddRefreshCookie; asserted here as the wire contract.
    private const string Cookie = "hostpoint_refresh";

    [Integration]
    [Fact]
    public async Task Web_login_sets_an_httpOnly_refresh_cookie_and_omits_it_from_the_body()
    {
        await using var app = new TestApp();
        var client = app.CreateClient(new WebApplicationFactoryClientOptions { HandleCookies = false });
        await Register(client);

        var res = await client.SendAsync(WebLogin());
        res.EnsureSuccessStatusCode();

        var setCookie = Assert.Single(res.Headers.GetValues("Set-Cookie"));
        Assert.Contains(Cookie, setCookie, StringComparison.Ordinal);
        Assert.Contains("httponly", setCookie, StringComparison.OrdinalIgnoreCase);

        var body = await res.Content.ReadAsStringAsync();
        Assert.Contains("accessToken", body, StringComparison.OrdinalIgnoreCase);
        Assert.DoesNotContain("refreshToken", body, StringComparison.OrdinalIgnoreCase);
    }

    [Integration]
    [Fact]
    public async Task Web_refresh_reads_the_cookie_with_no_body()
    {
        await using var app = new TestApp();
        var client = app.CreateClient(new WebApplicationFactoryClientOptions { HandleCookies = false });
        await Register(client);
        var cookie = CookieValue(await client.SendAsync(WebLogin()));

        var req = new HttpRequestMessage(HttpMethod.Post, "/account/refresh");
        req.Headers.Add("X-Client", "web");
        req.Headers.Add("Cookie", $"{Cookie}={cookie}");
        var res = await client.SendAsync(req);

        res.EnsureSuccessStatusCode();
        Assert.Contains(res.Headers.GetValues("Set-Cookie"), c => c.Contains(Cookie, StringComparison.Ordinal));
    }

    private static async Task Register(HttpClient client) =>
        (await client.PostAsJsonAsync("/account/register", new { email = "a@x.com", password = "password1" }))
            .EnsureSuccessStatusCode();

    private static HttpRequestMessage WebLogin()
    {
        var req = new HttpRequestMessage(HttpMethod.Post, "/account/login")
        {
            Content = JsonContent.Create(new { email = "a@x.com", password = "password1" }),
        };
        req.Headers.Add("X-Client", "web");
        return req;
    }

    private static string CookieValue(HttpResponseMessage res)
    {
        var setCookie = res.Headers.GetValues("Set-Cookie").First(c => c.StartsWith(Cookie, StringComparison.Ordinal));
        var pair = setCookie.Split(';')[0];                 // "hostpoint_refresh=VALUE"
        return pair[(pair.IndexOf('=') + 1)..];
    }
}
