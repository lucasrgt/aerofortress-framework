using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class LoginTests
{
    [Unit]
    [Fact]
    public async Task Issues_an_access_token_for_valid_credentials()
    {
        var store = Guid.NewGuid().ToString();
        await SeedUser(store, "a@x.com", "password1");

        await using var db = NewDb(store);
        var result = await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
        Assert.NotEmpty(result.Value.RefreshToken);
        Assert.Equal(RegistrationStep.EmailPending, result.Value.Step);
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_wrong_password()
    {
        var store = Guid.NewGuid().ToString();
        await SeedUser(store, "a@x.com", "password1");

        await using var db = NewDb(store);
        var result = await Login.Handle(new Login.Input("a@x.com", "wrong-password"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_email()
    {
        await using var db = NewDb();

        var result = await Login.Handle(new Login.Input("nobody@x.com", "password1"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    //<lz:tenancy>
    [Unit]
    [Fact]
    public async Task Signs_in_globally_regardless_of_the_request_org()
    {
        // Global identity: a user authenticates by email across every org. The unauthenticated login
        // request has no org of its own, so it must find the user (seeded in org A) all the same.
        var store = Guid.NewGuid().ToString();
        await SeedUser(store, "a@x.com", "password1", Guid.NewGuid());   // org A

        await using var db = NewDb(store, Guid.NewGuid());              // request carries a different org
        var result = await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
    }
    //</lz:tenancy>

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    //<lz:tenancy>
    private static async Task SeedUser(string store, string email, string password, Guid? org = null)
    {
        await using var db = NewDb(store, org);
        await Register.Handle(new Register.Input(email, password), db, TimeProvider.System, default);
    }

    private static AppDb NewDb(string? store = null, Guid? org = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options,
            new Tenant { OrgId = org ?? Guid.NewGuid() });
    //</lz:tenancy>
    //<lz:!tenancy>
    private static async Task SeedUser(string store, string email, string password)
    {
        await using var db = NewDb(store);
        await Register.Handle(new Register.Input(email, password), db, TimeProvider.System, default);
    }

    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options);
    //</lz:!tenancy>
}
