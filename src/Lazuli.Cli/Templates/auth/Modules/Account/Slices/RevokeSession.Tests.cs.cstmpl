using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class RevokeSessionTests
{
    [Unit]
    [Fact]
    public async Task Revokes_an_owned_session_and_leaves_the_others()
    {
        var (store, userId) = (Guid.NewGuid().ToString(), Guid.NewGuid());
        var target = Guid.NewGuid();
        var keep = Guid.NewGuid();
        var now = DateTime.UtcNow;
        await using (var db = NewDb(store))
        {
            db.UserSessions.Add(Session(userId, target, now));
            db.UserSessions.Add(Session(userId, keep, now));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(store);
        var result = await RevokeSession.Handle(new RevokeSession.Input(target), db2, new FakeUser(userId, keep), default);

        Assert.True(result.IsSuccess);
        Assert.False(await db2.UserSessions.AnyAsync(s => s.FamilyId == target));
        Assert.True(await db2.UserSessions.AnyAsync(s => s.FamilyId == keep));
    }

    [Unit]
    [Fact]
    public async Task Cannot_revoke_another_users_session()
    {
        var store = Guid.NewGuid().ToString();
        var userId = Guid.NewGuid();
        var otherUser = Guid.NewGuid();
        var theirFamily = Guid.NewGuid();
        await using (var db = NewDb(store))
        {
            db.UserSessions.Add(Session(otherUser, theirFamily, DateTime.UtcNow));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(store);
        var result = await RevokeSession.Handle(new RevokeSession.Input(theirFamily), db2, new FakeUser(userId, Guid.NewGuid()), default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.NotFound, result.Error.Kind);
        Assert.True(await db2.UserSessions.AnyAsync(s => s.FamilyId == theirFamily));
    }

    private static UserSession Session(Guid userId, Guid family, DateTime now) =>
        UserSession.Start(userId, family, family.ToString(), now).Value;

    //<lz:tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = Guid.NewGuid() });

    private sealed class FakeUser(Guid userId, Guid sessionId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public Guid OrgId => Guid.Empty;
        public string? Role => null;
        public Guid SessionId => sessionId;
    }
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options);

    private sealed class FakeUser(Guid userId, Guid sessionId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public string? Role => null;
        public Guid SessionId => sessionId;
    }
    //</lz:!tenancy>
}
