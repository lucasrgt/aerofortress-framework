using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class LogoutTests
{
    [Unit]
    [Fact]
    public async Task Revokes_the_session_so_the_refresh_is_dead()
    {
        var store = Guid.NewGuid().ToString();
        var refresh = await SeedAndLogin(store);

        await using (var db = NewDb(store))
            await Logout.Handle(new Logout.Input(refresh), db, default);

        await using var after = NewDb(store);
        var result = await Refresh.Handle(new Refresh.Input(refresh), after, Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Is_idempotent_for_an_unknown_token()
    {
        await using var db = NewDb();

        var result = await Logout.Handle(new Logout.Input("not-a-real-token"), db, default);

        Assert.True(result.IsSuccess);
    }

    private static async Task<string> SeedAndLogin(string store)
    {
        await using var db = NewDb(store);
        await Register.Handle(new Register.Input("a@x.com", "password1"), db, TimeProvider.System, default);
        var login = await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), TimeProvider.System, default);
        return login.Value.RefreshToken;
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    //<lz:tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options,
            new Tenant { OrgId = Guid.NewGuid() });
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options);
    //</lz:!tenancy>
}
