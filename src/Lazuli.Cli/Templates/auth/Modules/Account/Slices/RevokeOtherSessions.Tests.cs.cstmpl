using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.Modules.Account;
//<lz:tenancy>
using MyApp.Api.Tenancy;
//</lz:tenancy>
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class RevokeOtherSessionsTests
{
    [Unit]
    [Fact]
    public async Task Keeps_the_current_and_drops_the_rest()
    {
        var (store, userId) = (Guid.NewGuid().ToString(), Guid.NewGuid());
        var current = Guid.NewGuid();
        var now = DateTime.UtcNow;
        await using (var db = NewDb(store))
        {
            db.UserSessions.Add(Session(userId, current, now));
            db.UserSessions.Add(Session(userId, Guid.NewGuid(), now));
            db.UserSessions.Add(Session(userId, Guid.NewGuid(), now));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(store);
        var result = await RevokeOtherSessions.Handle(new RevokeOtherSessions.Input(), db2, new FakeUser(userId, current), default);

        Assert.True(result.IsSuccess);
        var remaining = await db2.UserSessions.Where(s => s.UserId == userId).Select(s => s.FamilyId).ToListAsync();
        Assert.Equal(new[] { current }, remaining);
    }

    [Unit]
    [Fact]
    public async Task Does_not_touch_another_users_sessions()
    {
        var (store, userId) = (Guid.NewGuid().ToString(), Guid.NewGuid());
        var current = Guid.NewGuid();
        var otherUser = Guid.NewGuid();
        var theirs = Guid.NewGuid();
        var now = DateTime.UtcNow;
        await using (var db = NewDb(store))
        {
            db.UserSessions.Add(Session(userId, current, now));
            db.UserSessions.Add(Session(userId, Guid.NewGuid(), now));
            db.UserSessions.Add(Session(otherUser, theirs, now));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(store);
        await RevokeOtherSessions.Handle(new RevokeOtherSessions.Input(), db2, new FakeUser(userId, current), default);

        Assert.True(await db2.UserSessions.AnyAsync(s => s.FamilyId == theirs));
        Assert.Equal(1, await db2.UserSessions.CountAsync(s => s.UserId == userId));
    }

    private static UserSession Session(Guid userId, Guid family, DateTime now) =>
        UserSession.Start(userId, family, family.ToString(), now).Value;

    //<lz:tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = Guid.NewGuid() });

    private sealed class FakeUser(Guid userId, Guid sessionId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public Guid OrgId => Guid.Empty;
        public string? Role => null;
        public Guid SessionId => sessionId;
    }
    //</lz:tenancy>
    //<lz:!tenancy>
    private static AppDb NewDb(string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options);

    private sealed class FakeUser(Guid userId, Guid sessionId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public string? Role => null;
        public Guid SessionId => sessionId;
    }
    //</lz:!tenancy>
}
