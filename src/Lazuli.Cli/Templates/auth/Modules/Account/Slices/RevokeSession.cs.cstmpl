using Lazuli.Auth;
using Microsoft.EntityFrameworkCore;

namespace Hostpoint.Api.Modules.Account;

/// <summary>Revoke one of the caller's sessions by its id (the refresh family). Only the owner can
/// revoke it; an unknown or another user's id is a not-found, never a hint that it exists. Reuses the
/// family-burn so every rotated slot in the lineage dies.</summary>
[Slice]
public static class RevokeSession
{
    public record Input(Guid SessionId);

    public record Output();

    public static async Task<Result<Output>> Handle(Input input, AppDb db, ICurrentUser current, CancellationToken ct)
    {
        var owned = await db.UserSessions.AnyAsync(s => s.FamilyId == input.SessionId && s.UserId == current.UserId, ct);
        if (!owned)
            return Error.NotFound("account.session_not_found", "session not found");

        await Refresh.RevokeFamily(db, input.SessionId, ct);
        return new Output();
    }

    public static void Map(IEndpointRouteBuilder app) =>
        app.MapPost("/sessions/revoke", async (Input input, AppDb db, ICurrentUser current, CancellationToken ct) =>
            (await Handle(input, db, current, ct)).ToHttp())
            .RequireAuthorization();
}
