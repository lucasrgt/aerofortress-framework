namespace Hostpoint.Api.Tenancy;

/// <summary>Marks an entity as belonging to one org. <see cref="TenantDbContext"/> applies a global
/// read filter to every entity carrying this marker, and stamps <see cref="OrgId"/> on insert — so
/// a query can never cross tenants and a slice never has to set the org by hand.</summary>
public interface ITenantScoped
{
    /// <summary>The owning org. Stamped on insert; never set by the caller.</summary>
    Guid OrgId { get; set; }
}
