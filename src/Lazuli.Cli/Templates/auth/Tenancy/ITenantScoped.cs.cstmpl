namespace MyApp.Api.Tenancy;

/// <summary>Marks an entity as belonging to one org. <see cref="TenantDbContext"/> applies a global
/// read filter to every entity carrying this marker, and stamps <see cref="OrgId"/> on insert — so
/// a query can never cross tenants and a slice never has to set the org by hand.</summary>
public interface ITenantScoped
{
    /// <summary>The owning org. Stamped on insert by <see cref="TenantDbContext"/> through EF property
    /// metadata; never set by the caller — so a tenant-scoped entity keeps it encapsulated
    /// (<c>public Guid OrgId { get; private set; }</c>), and a slice cannot leak across tenants.</summary>
    Guid OrgId { get; }
}
