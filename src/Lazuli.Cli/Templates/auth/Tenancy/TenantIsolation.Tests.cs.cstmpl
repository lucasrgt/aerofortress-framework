using MyApp.Api;
using MyApp.Api.BuildingBlocks;
using MyApp.Api.Modules.Account;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Tenancy;

public class TenantIsolationTests
{
    // The whole point of the pattern: two orgs share a store, but a read as org A can never see
    // org B's rows — and the OrgId is stamped on insert, not set by the caller.
    [Integration]
    [Fact]
    public async Task Reads_never_cross_the_current_org()
    {
        var orgA = Guid.NewGuid();
        var orgB = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();

        await Seed(store, orgA, "a@org-a.com");
        await Seed(store, orgB, "b@org-b.com");

        await using var db = NewDb(store, orgA);
        var users = await db.Users.ToListAsync();

        Assert.Single(users);
        Assert.Equal("a@org-a.com", users[0].Email.Value);
        Assert.Equal(orgA, users[0].OrgId);
    }

    private static async Task Seed(string store, Guid org, string email)
    {
        await using var db = NewDb(store, org);
        // OrgId not set here — stamped on save. PasswordHash is required; the dummy is fine, this
        // test only proves org isolation.
        db.Users.Add(new User { Email = Email.FromStored(email), PasswordHash = PasswordHash.FromStored("x.y") });
        await db.SaveChangesAsync();
    }

    private static AppDb NewDb(string store, Guid org) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
