using Hostpoint.Api;
using Lazuli.Auth;
using Hostpoint.Api.Modules.Account;
using Hostpoint.Api.Tenancy;
using Lazuli.Identity;
using Microsoft.EntityFrameworkCore;

namespace Hostpoint.Tests.Modules.Account;

public class RegisterWithGoogleTests
{
    [Unit]
    [Fact]
    public async Task Creates_an_email_verified_user_and_issues_a_session()
    {
        await using var db = NewDb(Guid.NewGuid());
        var result = await RegisterWithGoogle.Handle(new RegisterWithGoogle.Input("g@x.com"), db, new FakeExternalIdentity(), Tokens(), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.NotEmpty(result.Value.AccessToken);
        Assert.Equal(RegistrationStep.PhonePending, result.Value.Step);
        var user = await db.Users.IgnoreQueryFilters().FirstAsync();
        Assert.True(user.IsEmailVerified);
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_duplicate_email()
    {
        var store = Guid.NewGuid().ToString();
        await using (var db = NewDb(Guid.NewGuid(), store))
            await RegisterWithGoogle.Handle(new RegisterWithGoogle.Input("g@x.com"), db, new FakeExternalIdentity(), Tokens(), TimeProvider.System, default);

        await using var db2 = NewDb(Guid.NewGuid(), store);
        var result = await RegisterWithGoogle.Handle(new RegisterWithGoogle.Input("g@x.com"), db2, new FakeExternalIdentity(), Tokens(), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Conflict, result.Error.Kind);
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", TimeProvider.System);

    private static AppDb NewDb(Guid org, string? store = null) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store ?? Guid.NewGuid().ToString()).Options, new Tenant { OrgId = org });
}
