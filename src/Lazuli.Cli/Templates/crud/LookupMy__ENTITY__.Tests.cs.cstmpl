using MyApp.Api;
using MyApp.Api.Auth;
using MyApp.Api.Modules.__MODULE__;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.__MODULE__;

public class LookupMy__ENTITY__Tests
{
    [Unit]
    [Fact]
    public async Task Finds_the_callers_own_item()
    {
        var (store, org, userId) = (Guid.NewGuid().ToString(), Guid.NewGuid(), Guid.NewGuid());
        await using (var db = NewDb(org, store))
        {
            db.__PLURAL__.Add(Seed(org, userId));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(org, store);
        var result = await LookupMy__ENTITY__.Handle(new LookupMy__ENTITY__.Input(), db2, new FakeUser(userId, org), default);

        Assert.True(result.IsSuccess);
        Assert.Equal(userId, result.Value.Item.UserId);
    }

    [Unit]
    [Fact]
    public async Task No_item_for_the_caller_is_not_found()
    {
        var (store, org) = (Guid.NewGuid().ToString(), Guid.NewGuid());

        await using var db = NewDb(org, store);
        var result = await LookupMy__ENTITY__.Handle(new LookupMy__ENTITY__.Input(), db, new FakeUser(Guid.NewGuid(), org), default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.NotFound, result.Error.Kind);
    }

    private static __ENTITY__ Seed(Guid org, Guid userId) =>
        new() { Id = Guid.NewGuid(), OrgId = org, UserId = userId__SEED_ASSIGNMENTS____SEED_TIMESTAMPS__ };

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });

    private sealed class FakeUser(Guid userId, Guid orgId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public Guid OrgId => orgId;
        public string? Role => null;
        public Guid SessionId => Guid.Empty;
    }
}
