using MyApp.Api;
using MyApp.Api.Modules.__MODULE__;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.__MODULE__;

// __ENTITY__ has complex/VO fields the generator cannot construct, so a seeded round-trip is left to
// the owner. This degraded test proves the empty-store path; flesh out a seeded case once you can build
// a valid __ENTITY__ (set the VO/enum fields the generator listed).
public class List__ENTITY__Tests
{
    [Unit]
    [Fact]
    public async Task Empty_store_returns_no_items()
    {
        var (store, org) = (Guid.NewGuid().ToString(), Guid.NewGuid());

        await using var db = NewDb(org, store);
        var result = await List__ENTITY__.Handle(new List__ENTITY__.Input(null, null), db, default);

        Assert.True(result.IsSuccess);
        Assert.Empty(result.Value.Items);
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
