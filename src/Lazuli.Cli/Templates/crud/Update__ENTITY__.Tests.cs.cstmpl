using MyApp.Api;
using MyApp.Api.Modules.__MODULE__;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.__MODULE__;

public class Update__ENTITY__Tests
{
    [Unit]
    [Fact]
    public async Task Updates_an_existing_item()
    {
        var (store, org, id) = (Guid.NewGuid().ToString(), Guid.NewGuid(), Guid.NewGuid());
        await using (var db = NewDb(org, store))
        {
            db.__PLURAL__.Add(Seed(id, org));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(org, store);
        var result = await Update__ENTITY__.Handle(new Update__ENTITY__.Input(id__UPDATE_CALL_ARGS__), db2, TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        Assert.Equal(id, result.Value.Id);
    }

    [Unit]
    [Fact]
    public async Task Unknown_id_is_not_found()
    {
        var (store, org) = (Guid.NewGuid().ToString(), Guid.NewGuid());

        await using var db = NewDb(org, store);
        var result = await Update__ENTITY__.Handle(new Update__ENTITY__.Input(Guid.NewGuid()__UPDATE_NULL_ARGS__), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.NotFound, result.Error.Kind);
    }

    private static __ENTITY__ Seed(Guid id, Guid org) =>
        new() { Id = id, OrgId = org__SEED_ASSIGNMENTS____SEED_TIMESTAMPS__ };

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
