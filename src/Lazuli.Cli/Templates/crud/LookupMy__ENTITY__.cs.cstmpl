using MyApp.Api.Auth;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Api.Modules.__MODULE__;

/// <summary>Return the caller's own __ENTITY__ — the row whose UserId is the signed-in user. The owner
/// comes from the access token via <see cref="ICurrentUser"/>, so a user can only ever read their own.</summary>
[Slice]
public static class LookupMy__ENTITY__
{
    public record Input();

    public record Output(__ENTITY__ Item);

    public static async Task<Result<Output>> Handle(Input input, AppDb db, ICurrentUser current, CancellationToken ct)
    {
        var item = await db.__PLURAL__.FirstOrDefaultAsync(e => e.UserId == current.UserId, ct);
        return item is null ? Error.NotFound(__MODULE__ErrorCodes.__ENTITY__NotFound, "__ENTITY_LOWER__ not found") : new Output(item);
    }

    public static void Map(IEndpointRouteBuilder app) =>
        app.MapGet("/my-__ENTITY_LOWER__", async (AppDb db, ICurrentUser current, CancellationToken ct) =>
            (await Handle(new Input(), db, current, ct)).ToHttp())
            .RequireAuthorization();
}
