using Microsoft.EntityFrameworkCore;

namespace MyApp.Api.Modules.__MODULE__;

/// <summary>Delete a __ENTITY__ by id, scoped to the caller's tenant (hard delete). An unknown id is a
/// not-found, never a hint that the row exists in another org.</summary>
[Slice]
public static class Delete__ENTITY__
{
    public record Input(Guid Id);

    public record Output();

    public static async Task<Result<Output>> Handle(Input input, AppDb db, CancellationToken ct)
    {
        var item = await db.__PLURAL__.FirstOrDefaultAsync(e => e.Id == input.Id, ct);
        if (item is null)
            return Error.NotFound(__MODULE__ErrorCodes.__ENTITY__NotFound, "__ENTITY_LOWER__ not found");

        db.__PLURAL__.Remove(item);
        await db.SaveChangesAsync(ct);
        return new Output();
    }

    public static void Map(IEndpointRouteBuilder app) =>
        app.MapDelete("/__ENTITY_LOWER__/{id:guid}", async (Guid id, AppDb db, CancellationToken ct) =>
            (await Handle(new Input(id), db, ct)).ToHttp())
            .RequireAuthorization();
}
