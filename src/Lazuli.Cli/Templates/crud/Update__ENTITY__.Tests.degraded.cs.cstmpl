using Hostpoint.Api;
using Hostpoint.Api.Modules.__MODULE__;
using Hostpoint.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace Hostpoint.Tests.Modules.__MODULE__;

// __ENTITY__ has complex/VO fields the generator cannot construct, so a seeded update is left to the
// owner. This degraded test proves the not-found path; add an update-case once you can build a valid __ENTITY__.
public class Update__ENTITY__Tests
{
    [Unit]
    [Fact]
    public async Task Unknown_id_is_not_found()
    {
        var (store, org) = (Guid.NewGuid().ToString(), Guid.NewGuid());

        await using var db = NewDb(org, store);
        var result = await Update__ENTITY__.Handle(new Update__ENTITY__.Input(Guid.NewGuid()), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.NotFound, result.Error.Kind);
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
