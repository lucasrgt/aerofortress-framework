using Hostpoint.Api;
using Hostpoint.Api.Modules.__MODULE__;
using Hostpoint.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace Hostpoint.Tests.Modules.__MODULE__;

public class List__ENTITY__Tests
{
    [Unit]
    [Fact]
    public async Task Lists_the_tenants_items_newest_first()
    {
        var (store, org) = (Guid.NewGuid().ToString(), Guid.NewGuid());
        await using (var db = NewDb(org, store))
        {
            db.__PLURAL__.Add(Seed(org, DateTime.UtcNow.AddMinutes(-1)));
            db.__PLURAL__.Add(Seed(org, DateTime.UtcNow));
            await db.SaveChangesAsync();
        }

        await using var db2 = NewDb(org, store);
        var result = await List__ENTITY__.Handle(new List__ENTITY__.Input(null, null), db2, default);

        Assert.True(result.IsSuccess);
        Assert.Equal(2, result.Value.Items.Count);
    }

    private static __ENTITY__ Seed(Guid org, DateTime at) =>
        new() { Id = Guid.NewGuid(), OrgId = org__SEED_ASSIGNMENTS____SEED_TIMESTAMPS_AT__ };

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
