using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.BuildingBlocks;
using MyApp.Api.Modules.Account;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class VerifyPhoneTests
{
    [Unit]
    [Fact]
    public async Task Verifies_with_the_right_code_and_completes_registration()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store);
        await SeedOtp(org, store, userId, "123456");

        await using var db = NewDb(org, store);
        var result = await VerifyPhone.Handle(new VerifyPhone.Input("123456"), db, new FakeUser(userId), TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        var user = await db.Users.FirstAsync(u => u.Id == userId);
        Assert.True(user.IsPhoneVerified);
        Assert.Equal(RegistrationStep.Complete, user.RegistrationStep);
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_wrong_code()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store);
        await SeedOtp(org, store, userId, "123456");

        await using var db = NewDb(org, store);
        var result = await VerifyPhone.Handle(new VerifyPhone.Input("000000"), db, new FakeUser(userId), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Locks_the_code_after_five_wrong_attempts()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store);
        await SeedOtp(org, store, userId, "123456");

        // Five wrong guesses against a 6-digit code: the fifth trips the brute-force lock.
        for (var attempt = 0; attempt < 5; attempt++)
        {
            await using var db = NewDb(org, store);
            await VerifyPhone.Handle(new VerifyPhone.Input("000000"), db, new FakeUser(userId), TimeProvider.System, default);
        }

        // The correct code now fails — the locked code was consumed, so no active OTP remains to verify.
        await using var after = NewDb(org, store);
        var result = await VerifyPhone.Handle(new VerifyPhone.Input("123456"), after, new FakeUser(userId), TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
        var user = await after.Users.FirstAsync(u => u.Id == userId);
        Assert.False(user.IsPhoneVerified);
    }

    private static async Task SeedOtp(Guid org, string store, Guid userId, string code)
    {
        var now = DateTime.UtcNow;
        await using var db = NewDb(org, store);
        db.PhoneOtps.Add(PhoneOtp.Issue(userId, "+5511999999999", PasswordHash.Create(code).Value, now).Value);
        await db.SaveChangesAsync();
    }

    private static async Task<Guid> SeedUser(Guid org, string store)
    {
        await using var db = NewDb(org, store);
        var r = await Register.Handle(new Register.Input("a@x.com", "password1"), db, TimeProvider.System, default);
        return r.Value.UserId;
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });

    private sealed class FakeUser(Guid userId) : ICurrentUser
    {
        public bool IsAuthenticated => true;
        public Guid UserId => userId;
        public Guid OrgId => Guid.Empty;
        public string? Role => null;
        public Guid SessionId => Guid.Empty;
    }
}
