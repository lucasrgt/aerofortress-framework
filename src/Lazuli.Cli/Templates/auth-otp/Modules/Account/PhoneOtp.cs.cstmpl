namespace MyApp.Api.Modules.Account;

/// <summary>A one-time phone-verification code — a domain entity that owns its lifecycle. <b>Not</b>
/// <c>ITenantScoped</c>: like <see cref="UserSession"/>, it is a global auth artifact keyed by the user,
/// looked up directly by <see cref="UserId"/>. Unlike the token entities, the code is <em>low-entropy</em>
/// (6 digits), so it is hashed with argon2id (<see cref="PasswordHash"/>) — a fast SHA-256 would be
/// brute-forceable — and verified, not looked up by hash. A wrong guess is recorded with
/// <see cref="RecordAttempt"/>; using or locking the code goes through <see cref="Use"/>.</summary>
[Entity]
public class PhoneOtp
{
    /// <summary>How long a freshly-issued code stays valid.</summary>
    public static readonly TimeSpan CodeLifetime = TimeSpan.FromMinutes(10);

    /// <summary>The code's identity, assigned when it is issued.</summary>
    public Guid Id { get; private set; }

    /// <summary>The user the code was issued to.</summary>
    public Guid UserId { get; private set; }

    /// <summary>The phone number being verified.</summary>
    public string Phone { get; private set; } = "";

    /// <summary>The argon2id hash of the 6-digit code — the code itself is never stored.</summary>
    public string CodeHash { get; private set; } = "";

    /// <summary>When the code expires.</summary>
    public DateTime ExpiresAt { get; private set; }

    /// <summary>When the code was consumed (verified or locked). Null while it is still usable.</summary>
    public DateTime? UsedAt { get; private set; }

    /// <summary>How many wrong guesses have been made — the brute-force counter.</summary>
    public int Attempts { get; private set; }

    /// <summary>When the code was issued.</summary>
    public DateTime CreatedAt { get; private set; }

    /// <summary>The optimistic-concurrency token (LZ0026): a concurrent verify against the same code fails
    /// loudly instead of two requests both racing the attempt counter.</summary>
    [System.ComponentModel.DataAnnotations.Timestamp]
    public byte[]? RowVersion { get; private set; }

    // Parameterless and private: the constructor EF Core materialises a row through. A code is issued via
    // Issue, so there is no public way to construct a blank one.
    private PhoneOtp() { }

    /// <summary>Issue a fresh code for <paramref name="userId"/> / <paramref name="phone"/>, carrying its
    /// argon2 hash and expiring one <see cref="CodeLifetime"/> from <paramref name="now"/>. Creation funnels
    /// through <see cref="EnsureValid"/>.</summary>
    public static Result<PhoneOtp> Issue(Guid userId, string phone, string codeHash, DateTime now) =>
        new PhoneOtp
        {
            Id = Guid.NewGuid(),
            UserId = userId,
            Phone = phone,
            CodeHash = codeHash,
            ExpiresAt = now.Add(CodeLifetime),
            CreatedAt = now,
        }.EnsureValid();

    /// <summary>Record a wrong guess. Bumps the brute-force counter; cannot fail — a void mutation.</summary>
    public void RecordAttempt() => Attempts++;

    /// <summary>Consume the code at <paramref name="now"/> — on a correct guess or when the attempt ceiling
    /// locks it. A used code can never be tried again. Cannot fail — a void mutation.</summary>
    public void Use(DateTime now) => UsedAt = now;

    // The single invariant funnel: every create path returns through here, so a broken code can never be
    // observed or persisted.
    private Result<PhoneOtp> EnsureValid()
    {
        var validation = new Validation()
            .Require(Id, "id", AccountErrorCodes.InvalidState)
            .Require(UserId, "userId", AccountErrorCodes.InvalidState)
            .NotBlank(CodeHash, "codeHash", AccountErrorCodes.InvalidState);
        if (validation.Failed)
            return validation.ToError();
        return this;
    }
}
