using System.Net;
using System.Net.Http.Headers;
using System.Net.Http.Json;
using Hostpoint.Api.Modules.Account;
using Lazuli.Mail;
using Microsoft.AspNetCore.Hosting;
using Microsoft.Extensions.DependencyInjection;

namespace Hostpoint.Tests.Journeys;

// Journeys for the [Critical] email-token slices (ResetPassword, VerifyEmail). Like the SMS code, the token
// only leaves the system as an email — it is hashed in storage — so the test layers a capturing IEmailSender
// over the booted app (the last registration wins) to read the token the real Request* slice sent. Same seam
// as the phone journey, over a different provider. LZ0008 requires a happy and a sad per critical slice.
public class EmailJourney
{
    private const string Email = "reset@example.com";
    private const string Password = "password1";

    private sealed record Tokens(string AccessToken, string RefreshToken);

    // The Request* slices put the raw token at the end of the body ("...with this token: ABC") — read it back.
    private sealed class CapturingEmailSender : IEmailSender
    {
        public string? LastToken { get; private set; }

        public Task SendAsync(EmailMessage message, CancellationToken ct = default)
        {
            LastToken = message.Body[(message.Body.LastIndexOf(' ') + 1)..];
            return Task.CompletedTask;
        }
    }

    [E2E]
    [Journey(typeof(ResetPassword), JourneyPath.Happy)]
    [Fact]
    public async Task A_reset_token_sets_a_new_password()
    {
        var mail = new CapturingEmailSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<IEmailSender>(mail)));
        var client = factory.CreateClient();
        await Register(client);

        await client.PostAsJsonAsync("/account/password-reset/request", new { email = Email });
        var reset = await client.PostAsJsonAsync("/account/password-reset", new { token = mail.LastToken, newPassword = "new-password1" });
        reset.EnsureSuccessStatusCode();

        var login = await client.PostAsJsonAsync("/account/login", new { email = Email, password = "new-password1" });
        login.EnsureSuccessStatusCode();
    }

    // The takeover guard: a wrong token is rejected AND leaves the password unchanged — the original still
    // logs in, the attempted new one does not. A silent pass here would let anyone reset any account.
    [E2E]
    [Journey(typeof(ResetPassword), JourneyPath.Sad)]
    [Fact]
    public async Task A_wrong_reset_token_is_rejected_and_the_password_is_unchanged()
    {
        var mail = new CapturingEmailSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<IEmailSender>(mail)));
        var client = factory.CreateClient();
        await Register(client);
        await client.PostAsJsonAsync("/account/password-reset/request", new { email = Email });

        var reset = await client.PostAsJsonAsync("/account/password-reset", new { token = "not-a-real-token", newPassword = "new-password1" });
        Assert.Equal(HttpStatusCode.Unauthorized, reset.StatusCode);

        var original = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        original.EnsureSuccessStatusCode();   // unchanged
        var attempted = await client.PostAsJsonAsync("/account/login", new { email = Email, password = "new-password1" });
        Assert.Equal(HttpStatusCode.Unauthorized, attempted.StatusCode);
    }

    [E2E]
    [Journey(typeof(VerifyEmail), JourneyPath.Happy)]
    [Fact]
    public async Task An_email_token_confirms_the_email()
    {
        var mail = new CapturingEmailSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<IEmailSender>(mail)));
        var client = factory.CreateClient();
        await Authenticate(client);

        await client.PostAsJsonAsync("/account/verify-email/request", new { });
        var verify = await client.PostAsJsonAsync("/account/verify-email", new { token = mail.LastToken });

        verify.EnsureSuccessStatusCode();
    }

    // The bypass guard: a wrong token is rejected, and it neither falsely confirms nor consumes the real
    // token — the genuine one still confirms right after.
    [E2E]
    [Journey(typeof(VerifyEmail), JourneyPath.Sad)]
    [Fact]
    public async Task A_wrong_email_token_is_rejected_and_the_real_one_still_confirms()
    {
        var mail = new CapturingEmailSender();
        await using var app = new TestApp();
        using var factory = app.WithWebHostBuilder(b => b.ConfigureServices(s => s.AddSingleton<IEmailSender>(mail)));
        var client = factory.CreateClient();
        await Authenticate(client);
        await client.PostAsJsonAsync("/account/verify-email/request", new { });

        var wrong = await client.PostAsJsonAsync("/account/verify-email", new { token = "not-a-real-token" });
        Assert.Equal(HttpStatusCode.Unauthorized, wrong.StatusCode);

        var verify = await client.PostAsJsonAsync("/account/verify-email", new { token = mail.LastToken });
        verify.EnsureSuccessStatusCode();
    }

    private static async Task Register(HttpClient client) =>
        (await client.PostAsJsonAsync("/account/register", new { email = Email, password = Password }))
            .EnsureSuccessStatusCode();

    private static async Task Authenticate(HttpClient client)
    {
        await Register(client);
        var login = await client.PostAsJsonAsync("/account/login", new { email = Email, password = Password });
        login.EnsureSuccessStatusCode();
        var tokens = await login.Content.ReadFromJsonAsync<Tokens>();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", tokens!.AccessToken);
    }
}
