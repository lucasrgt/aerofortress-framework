using Hostpoint.Api;
using Hostpoint.Api.Modules.Account;
using Hostpoint.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace Hostpoint.Tests.Modules.Account;

public class VerifyEmailTests
{
    [Unit]
    [Fact]
    public async Task Marks_the_user_verified_with_a_valid_token()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store);
        var raw = await SeedToken(org, store, userId);

        await using var db = NewDb(org, store);
        var result = await VerifyEmail.Handle(new VerifyEmail.Input(raw), db, TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        var user = await db.Users.IgnoreQueryFilters().FirstAsync(u => u.Id == userId);
        Assert.True(user.IsEmailVerified);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_token()
    {
        await using var db = NewDb(Guid.NewGuid(), Guid.NewGuid().ToString());
        var result = await VerifyEmail.Handle(new VerifyEmail.Input("nope"), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    private static async Task<string> SeedToken(Guid org, string store, Guid userId)
    {
        var now = DateTime.UtcNow;
        var (raw, hash) = SessionToken.Issue();
        await using var db = NewDb(org, store);
        db.EmailVerificationTokens.Add(new EmailVerificationToken
        {
            UserId = userId,
            TokenHash = hash,
            ExpiresAt = now.AddHours(24),
            CreatedAt = now,
        });
        await db.SaveChangesAsync();
        return raw;
    }

    private static async Task<Guid> SeedUser(Guid org, string store)
    {
        await using var db = NewDb(org, store);
        var r = await Register.Handle(new Register.Input("a@x.com", "password1"), db, TimeProvider.System, default);
        return r.Value.UserId;
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
