using MyApp.Api;
using Lazuli.Auth;
using MyApp.Api.Modules.Account;
using MyApp.Api.Tenancy;
using Microsoft.EntityFrameworkCore;

namespace MyApp.Tests.Modules.Account;

public class ResetPasswordTests
{
    [Unit]
    [Fact]
    public async Task Sets_a_new_password_with_a_valid_token()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store, "a@x.com");
        var raw = await SeedToken(org, store, userId);

        await using var db = NewDb(org, store);
        var result = await ResetPassword.Handle(new ResetPassword.Input(raw, "new-password1"), db, TimeProvider.System, default);

        Assert.True(result.IsSuccess);
        var user = await db.Users.IgnoreQueryFilters().FirstAsync(u => u.Id == userId);
        Assert.True(user.PasswordHash.Verify("new-password1"));
    }

    [Unit]
    [Fact]
    public async Task Rejects_a_short_password()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store, "a@x.com");
        var raw = await SeedToken(org, store, userId);

        await using var db = NewDb(org, store);
        var result = await ResetPassword.Handle(new ResetPassword.Input(raw, "short"), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Validation, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Rejects_an_unknown_token()
    {
        await using var db = NewDb(Guid.NewGuid(), Guid.NewGuid().ToString());
        var result = await ResetPassword.Handle(new ResetPassword.Input("nope", "new-password1"), db, TimeProvider.System, default);

        Assert.True(result.IsFailure);
        Assert.Equal(ErrorKind.Unauthorized, result.Error.Kind);
    }

    [Unit]
    [Fact]
    public async Task Reset_revokes_existing_sessions()
    {
        var org = Guid.NewGuid();
        var store = Guid.NewGuid().ToString();
        var userId = await SeedUser(org, store, "a@x.com");

        // A live session from before the reset (the attacker's, in the takeover-recovery story).
        string refresh;
        await using (var db = NewDb(org, store))
            refresh = (await Login.Handle(new Login.Input("a@x.com", "password1"), db, Tokens(), TimeProvider.System, default)).Value.RefreshToken;

        var raw = await SeedToken(org, store, userId);
        await using (var db = NewDb(org, store))
            await ResetPassword.Handle(new ResetPassword.Input(raw, "new-password1"), db, TimeProvider.System, default);

        // The pre-reset refresh token is dead — its family was revoked by the password change.
        await using (var db = NewDb(org, store))
        {
            var result = await Refresh.Handle(new Refresh.Input(refresh), db, Tokens(), TimeProvider.System, default);
            Assert.True(result.IsFailure);
        }
    }

    private static IAccessTokens Tokens() =>
        new AccessTokens("test-secret-for-jwt-signing-please-32+chars", "myapp", "myapp", TimeProvider.System);

    private static async Task<string> SeedToken(Guid org, string store, Guid userId)
    {
        var now = DateTime.UtcNow;
        var (raw, hash) = SessionToken.Issue();
        await using var db = NewDb(org, store);
        db.PasswordResetTokens.Add(new PasswordResetToken
        {
            UserId = userId,
            TokenHash = hash,
            ExpiresAt = now.AddHours(1),
            CreatedAt = now,
        });
        await db.SaveChangesAsync();
        return raw;
    }

    private static async Task<Guid> SeedUser(Guid org, string store, string email)
    {
        await using var db = NewDb(org, store);
        var r = await Register.Handle(new Register.Input(email, "password1"), db, TimeProvider.System, default);
        return r.Value.UserId;
    }

    private static AppDb NewDb(Guid org, string store) =>
        new(new DbContextOptionsBuilder<AppDb>().UseInMemoryDatabase(store).Options, new Tenant { OrgId = org });
}
